# Server
PORT=3000

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=whatsapp_bot
DATABASE_USER=botuser
DATABASE_PASSWORD=secure-password-here

# Authentication
JWT_SECRET=random-secret-string-here
ADMIN_SECRET=registration-secret-for-first-professor

# AI (Professor admin assistant — OpenAI REST API)
OPENAI_API_KEY=sk-your-key-here

# Clawdbot Gateway (WhatsApp bridge)
CLAWDBOT_GATEWAY_URL=ws://127.0.0.1:18789
CLAWDBOT_GATEWAY_TOKEN=your-gateway-auth-token
BOT_PHONE_NUMBER=+1234567890

# Canvas LMS (optional — for assignment reminders)
# CANVAS_API_TOKEN=your-canvas-token
# CANVAS_BASE_URL=https://canvas.youruniversity.edu
# CANVAS_COURSE_ID=12345

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
